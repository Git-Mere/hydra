DISCORD_TOKEN=your_discord_bot_token
OPENROUTER_API_KEY=sk-or-xxxxxxxx

# Single OpenRouter model used for every channel. Optional; falls back to a
# sensible default in config.py (DEFAULT_MODEL) when unset.
DEFAULT_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Optional. Enables web search in chat mode via Tavily's remote MCP server.
# Without it, chat still works but answers without searching the web.
TAVILY_API_KEY=
