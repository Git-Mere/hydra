# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# --- Required ---

# Discord bot token (Developer Portal -> your app -> Bot -> Reset Token).
DISCORD_TOKEN=your_discord_bot_token

# OpenRouter API key (https://openrouter.ai/keys). Used as the fallback LLM
# provider for every mode, and as the primary provider when GEMINI_API_KEY is
# not set.
OPENROUTER_API_KEY=sk-or-xxxxxxxx

# --- Primary LLM provider (recommended) ---

# Google AI Studio key (https://aistudio.google.com/apikey). When set, Gemini
# (gemini-flash-lite-latest, via the OpenAI-compatible endpoint) is the primary
# provider for both translate and web search; OpenRouter is the fallback.
# GOOGLE_API_KEY is accepted as an alias. Leave unset to run on OpenRouter only.
GEMINI_API_KEY=

# --- Web search (optional) ---

# Tavily key (https://app.tavily.com) for web searching mode's MCP search.
# Without it, web searching mode replies that search is unavailable instead of
# answering from model memory. Translate mode does not need it.
TAVILY_API_KEY=

# --- Optional model overrides ---
# Sensible defaults live in config.py; set these only to override.

# Comma-separated OpenRouter fallback chain for translate mode. A single
# DEFAULT_MODEL is also honored (moved to the front of the built-in chain).
# MODEL_CHAIN=openai/gpt-oss-20b:free,qwen/qwen3-next-80b-a3b-instruct:free
# DEFAULT_MODEL=openai/gpt-oss-20b:free

# Comma-separated OpenRouter fallback chain for web searching mode (isolated
# from the translate chain).
# WEBSEARCH_MODEL_CHAIN=qwen/qwen3-next-80b-a3b-instruct:free,meta-llama/llama-3.3-70b-instruct:free

# --- Optional OpenRouter app attribution headers ---
# OPENROUTER_HTTP_REFERER=https://your-app.example
# OPENROUTER_X_TITLE=Discord Multi-Bot
